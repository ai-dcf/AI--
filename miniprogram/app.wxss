page {
  --brand-color: #0052D9;
  --brand-color-light: #E8F0FE;
  --brand-color-hover: #003CAB;
  --td-bg: #F5F5F5;
  --td-card: #FFFFFF;
  --td-text: #1a1a1a;
  --td-text-secondary: #999999;
  --td-text-placeholder: #BBBBBB;
  --td-border: #E7E7E7;
  --td-success: #00A870;
  --td-warning: #ED7B2F;
  --td-danger: #D54941;

  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, 'PingFang SC', 'Microsoft YaHei', Arial, sans-serif;
  background-color: var(--td-bg);
  color: var(--td-text);
  font-size: 28rpx;
  line-height: 1.5;
}

view, text, image {
  box-sizing: border-box;
}

.safe-area-bottom {
  padding-bottom: env(safe-area-inset-bottom, 0);
}
