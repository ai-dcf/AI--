<view class="home-page">
  <scroll-view
    class="gallery-scroll"
    scroll-y
    enhanced
    show-scrollbar="{{false}}"
    bindscrolltolower="onScrollToLower"
    lower-threshold="200"
  >
    <view class="gallery-waterfall">
      <view class="waterfall-column waterfall-left">
        <view
          class="gallery-card"
          wx:for="{{galleryList}}"
          wx:if="{{index % 2 === 0}}"
          wx:key="id"
          data-id="{{item.id}}"
          bindtap="onImageTap"
        >
          <image
            class="card-image"
            src="{{item.imageUrl}}"
            mode="widthFix"
            lazy-load
          />
          <view class="card-info">
            <text class="card-prompt">{{item.prompt}}</text>
            <view class="card-author">
              <image class="author-avatar" src="{{item.avatarUrl}}" />
              <text class="author-name">{{item.nickName}}</text>
            </view>
          </view>
        </view>
      </view>
      <view class="waterfall-column waterfall-right">
        <view
          class="gallery-card"
          wx:for="{{galleryList}}"
          wx:if="{{index % 2 === 1}}"
          wx:key="id"
          data-id="{{item.id}}"
          bindtap="onImageTap"
        >
          <image
            class="card-image"
            src="{{item.imageUrl}}"
            mode="widthFix"
            lazy-load
          />
          <view class="card-info">
            <text class="card-prompt">{{item.prompt}}</text>
            <view class="card-author">
              <image class="author-avatar" src="{{item.avatarUrl}}" />
              <text class="author-name">{{item.nickName}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="loading-footer" wx:if="{{loadingMore}}">
      <t-loading theme="circular" size="40rpx" text="加载更多画作..." />
    </view>

    <view class="no-more" wx:if="{{!hasMore && galleryList.length > 0}}">
      <text class="no-more-text">— 已经到底了 —</text>
    </view>

    <view class="scroll-bottom-spacer"></view>
  </scroll-view>

  <view class="fab-btn" bindtap="onFabTap">
    <t-icon name="add" size="48rpx" color="#fff" />
  </view>

  <view class="loading-mask" wx:if="{{loading}}">
    <t-loading theme="circular" size="80rpx" />
  </view>
</view>
